# ============================================================
# ERC-8004 Deep Agent Kit - LIVE Circle DCW only
# ============================================================
# This package is live-only: commands are designed for Arc Testnet + Circle DCW validation.

# LLM provider. Needed only for `agent-register`. Direct CLI commands do not need an LLM.
DEEPAGENT_MODEL=anthropic:claude-sonnet-4-6
ANTHROPIC_API_KEY=***

# Network profile.
NETWORK_PROFILE=arc-testnet
CHAIN_ID=5042002
BLOCKCHAIN=ARC-TESTNET
RPC_URL=https://rpc.drpc.testnet.arc.network
EXPLORER_URL=https://testnet.arcscan.app
ERC8004_FROM_BLOCK=41338000
EVENT_SCAN_BLOCK_RANGE=10000
VERIFY_CHAIN_ID=true
RECEIPT_POLL_SECONDS=3
RECEIPT_MAX_POLLS=60
REGISTRATION_LOCK_TTL_SECONDS=1260

# ERC-8004 registry addresses on Arc Testnet.
IDENTITY_REGISTRY=0x8004A818BFB912233c491871b3d84c89A494BD9e
REPUTATION_REGISTRY=0x8004B663056A597Dffe9eCcC1965A193B7388713
VALIDATION_REGISTRY=0x8004Cb1BF31DAf7788923b405b754f57acEB4272

# Circle Developer-Controlled Wallets. Do not commit real values.
CIRCLE_API_KEY=***
CIRCLE_ENTITY_SECRET=
DCW_WALLET_ADDRESS=

# Local state. Persist these paths with Docker volume.
IDENTITY_STORE_PATH=/data/erc8004_identities.sqlite3
CIRCLE_EXECUTION_STATE_DIR=/data/circle_executions

# Agent registration metadata.
AGENT_KEY=default-agent
AGENT_NAME=Example ERC-8004 Deep Agent
AGENT_DESCRIPTION=LangChain Deep Agent with ERC-8004 identity, reputation, validation, and x402 payment tools.
AGENT_IMAGE=https://example.com/agent.png
# JSON array. Example:
# AGENT_SERVICES_JSON=[{"name":"MCP","endpoint":"https://example.com/mcp","version":"2025-06-18"}]
AGENT_SERVICES_JSON=[]
AGENT_SUPPORTED_TRUST_JSON=["reputation", "validation"]
AGENT_X402_SUPPORT=false

# ============================================================
# x402 Payment Settings
# ============================================================
# Enable x402 payment tools for the Deep Agent.
X402_ENABLED=false

# Mode: "batching" (Circle x402-batching, high-frequency) or "nano" (standalone, simple).
X402_MODE=batching

# Gateway API URL (Arc Testnet default).
X402_GATEWAY_API_URL=https://gateway-api-testnet.circle.com

# Circle DCW wallet ID for buyer role. From env only — LLM cannot override.
X402_DEFAULT_BUYER_WALLET_ID=

# EVM address for seller role.
X402_DEFAULT_SELLER_WALLET_ADDRESS=

# Comma-separated allowed hosts for buyer requests. Empty = block ALL (fail-closed).
X402_ALLOWED_HOSTS=

# Require HTTPS for buyer requests.
X402_REQUIRE_HTTPS=true

# Maximum payment per single x402 request (USDC, display units).
X402_MAX_PER_REQUEST_USDC=0.000001

# Daily budget cap (USDC).
X402_MAX_DAILY_USDC=0.01

# Maximum number of x402 requests per day.
X402_MAX_REQUESTS_PER_DAY=100

# SQLite spend ledger path.
X402_LEDGER_PATH=/data/x402_spend_ledger.sqlite3

# Agent exposure controls (which tools the Deep Agent can use).
X402_EXPOSE_BALANCE_TO_AGENT=true
X402_EXPOSE_BATCH_BUYER_TO_AGENT=false
X402_EXPOSE_BATCH_SELLER_TO_AGENT=false
X402_EXPOSE_NANO_BUYER_TO_AGENT=false
X402_EXPOSE_NANO_SELLER_TO_AGENT=false

# ERC-8004 Reputation Indexer
REPUTATION_STORE_PATH=/data/erc8004_reputation.sqlite3
REPUTATION_INDEXER_FROM_BLOCK=41338000
REPUTATION_INDEXER_BLOCK_RANGE=10000

# Dedicated client/reviewer wallet for reputation writes.
# Must NOT be the same as DCW_WALLET_ADDRESS for the target agent.
REPUTATION_WRITER_WALLET_ADDRESS=

# Reputation/validation write gates. Keep disabled for identity-bootstrap v1.
ENABLE_REPUTATION_WRITES=false
ENABLE_VALIDATION_WRITES=false
EXPOSE_REPUTATION_WRITE_TOOLS_TO_AGENT=false
EXPOSE_VALIDATION_WRITE_TOOLS_TO_AGENT=false

# Circle sidecar polling.
CIRCLE_TX_POLL_SECONDS=5
CIRCLE_TX_MAX_POLLS=180
CIRCLE_FEE_LEVEL=MEDIUM
